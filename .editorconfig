# https://editorconfig.org/

# Top-most EditorConfig file
root = true

# Unix-style shell scripts (Bash, Zsh)
[*.{sh,zsh}]
charset = utf-8
end_of_line = lf
insert_final_newline = false
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# PowerShell scripts
[*.{ps1,psm1}]
charset = utf-8
end_of_line = lf
insert_final_newline = false
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Markdown
[*.md]
charset = utf-8
end_of_line = lf
insert_final_newline = false
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2
insert_final_newline = false
end_of_line = lf
charset = utf-8

# YAML files
[*.yml]
indent_style = space
indent_size = 2
insert_final_newline = false
end_of_line = lf

# Dockerfiles
[*dockerfile]
indent_style = space
indent_size = 2

# HTML templates
[*.html]
indent_style = space
indent_size = 2

# Catch-all rule for all other files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = false
